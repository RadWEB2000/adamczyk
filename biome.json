{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off",
        "noCommentText":"warn",
        "noConsole":"warn",
        "noDuplicateObjectKeys":"warn",
        "noDuplicateProperties":"warn"
      },
      "a11y":{
        "noSvgWithoutTitle":"on",
        "useHtmlLang":"error",
        "useAltText":"warn"
      },
      "performance":{
        "noImgElement":"info"
      },
      "security":{
        "noDangerouslySetInnerHtml":"off",
        "noBlankTarget":"off",
        "noDangerouslySetInnerHtmlWithChildren":"off"
      },
      "style":{
        "noHeadElement":"warn",
        "noExportedImports":"warn",
        "noYodaExpression":"warn"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedAttributes":"on",
        "useSortedProperties":"on"
      }
    }
  }
}
